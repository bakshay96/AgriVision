# Server Environment Variables
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/agrivision_pro

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Gemini Vision AI
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta

# CORS
CLIENT_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# AWS S3 Configuration (for image uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET_NAME=your-bucket-name
AWS_REGION=ap-south-1

# Optional: Custom Gemini Model
# GEMINI_MODEL=gemini-2.5-flash

# Google Maps Geocoding API Key (Server-side)
# Get your free API key from: https://developers.google.com/maps/documentation/geocoding/get-api-key
# Free tier: 40,000 requests/month
# Note: Restrict this key to your server IP for security
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# OpenWeather API Key (for real weather data)
# Get from: https://openweathermap.org/api (Free tier available)
OPENWEATHER_API_KEY=your_openweather_api_key_here
