# Production Environment Variables for Netlify
# Copy this to .env.production and update with your actual values
# DO NOT commit .env.production to Git!

# Backend API URL (your deployed backend server)
NEXT_PUBLIC_API_URL=https://your-backend-server.com/api

# WebSocket Server URL (for real-time features)
NEXT_PUBLIC_SOCKET_URL=https://your-backend-server.com

# Note: These variables will be set in Netlify dashboard during deployment
# Go to: Site settings → Environment variables → Add variables
